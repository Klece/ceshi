                    </h2>
                    <div class="max-w-none" id="readme-content">
                        <p>一个16岁的高中生，喜欢打羽毛球，平常爱折腾一下</p>
<h2 id="_1">测试</h2>
<p><img alt="neko" src="content/image.png" /></p>
                    </div>
                </div>

                <!-- 我的项目 -->
                <div class="glass-panel bg-white/30 dark:bg-gray-800/30 rounded-2xl shadow-xl p-6 mt-6 card-hover animate-fade-in" style="animation-delay: 0.4s;">
                    <h2 class="text-2xl font-bold mb-4 flex items-center">
                        <i class="fa-solid fa-folder-open text-primary dark:text-primary-dark mr-2"></i>
                        我的项目
                    </h2>
                    <div class="space-y-4">
                        
                            
                                <a href="https://github.com/Klece/Kleceblog" target="_blank" rel="noopener noreferrer" class="block p-4 bg-gray-50 dark:bg-gray-700 rounded-xl repo-item hover:bg-gray-100 dark:hover:bg-gray-600">
                                    <div class="flex justify-between items-start mb-2">
                                        <h3 class="text-lg font-semibold text-primary dark:text-primary-dark">Kleceblog</h3>
                                        <span class="text-sm text-gray-500 dark:text-gray-400 flex items-center">
                                            <i class="fa-solid fa-star mr-1"></i>
                                            0
                                        </span>
                                    </div>
                                    <p class="text-gray-600 dark:text-gray-400 text-sm mb-2">一个静态的blog，无需服务器即可部署，个人二改</p>
                                    <div class="flex flex-wrap gap-2 mb-2">
                                        
                                            <span class="px-2 py-1 bg-blue-100 dark:bg-blue-900 text-blue-800 dark:text-blue-200 rounded text-xs">HTML</span>
                                        
                                    </div>
                                    <div class="flex justify-between items-center text-xs text-gray-500 dark:text-gray-400">
                                        <span><i class="fa-solid fa-code mr-1"></i>HTML</span>
                                        <span>更新于 2026-04-05</span>
                                    </div>
                                </a>
                            
                        
                    </div>
                </div>
            </div>
        </div>
    </main>

    <!-- 页脚 -->
    <footer class="glass-panel bg-white/30 dark:bg-gray-800/30 shadow-inner py-6">
        <div class="container mx-auto px-4 text-center text-gray-600 dark:text-gray-400">
            <p>到底了</p>
            <div class="mt-3 space-x-4">
                <!-- 联系方式图标，仅在配置了有效URL时显示 -->
                
                
                
                
            </div>
        </div>
    </footer>

    <!-- JavaScript -->
    <script>
        // 日期更新函数
        function updateDate() {
            const now = new Date();
            const year = now.getFullYear();
            const month = now.getMonth() + 1;
            const day = now.getDate();
            const weekDays = ['星期日', '星期一', '星期二', '星期三', '星期四', '星期五', '星期六'];
            const weekDay = weekDays[now.getDay()];

            const currentDate = document.getElementById('currentDate');
            const currentWeekday = document.getElementById('currentWeekday');

            if (currentDate) {
                currentDate.textContent = `${year}年${month}月${day}日`;
            }
            if (currentWeekday) {
                currentWeekday.textContent = weekDay;
            }
        }
        
        // 复制到剪贴板函数
        function copyToClipboard(text, name) {
            navigator.clipboard.writeText(text).then(function() {
                alert(name + ' ' + text + ' 已复制到剪贴板！');
            }, function(err) {
                console.error('复制失败: ', err);
                // 如果navigator.clipboard不可用，使用传统方法
                const textArea = document.createElement("textarea");
                textArea.value = text;
                document.body.appendChild(textArea);
                textArea.select();
                try {
                    document.execCommand('copy');
                    alert(name + ' ' + text + ' 已复制到剪贴板！');
                } catch (err) {
                    console.error('复制失败: ', err);
                    alert('复制失败，请手动复制：' + text);
                }
                document.body.removeChild(textArea);
            });
        }
        
        // 深色模式切换
        document.addEventListener('DOMContentLoaded', function() {
            const themeToggle = document.getElementById('theme-toggle');
            const htmlElement = document.documentElement;
            
            // 日期显示
            updateDate();
            setInterval(updateDate, 1000);

            // 初始化贡献统计图表
            const ctx = document.getElementById('contributionChart');
            if (ctx) {
                // 使用后端传递的真实贡献数据
                const contributions = [{"count": 0, "date": "03/30"}, {"count": 0, "date": "03/31"}, {"count": 0, "date": "04/01"}, {"count": 0, "date": "04/02"}, {"count": 0, "date": "04/03"}, {"count": 0, "date": "04/04"}, {"count": 4, "date": "04/05"}];
                const labels = contributions.map(c => c.date);
                const data = contributions.map(c => c.count);

                // 找到最高提交次数作为顶点
                const maxCount = Math.max(...data);

                new Chart(ctx, {
                    type: 'line',
                    data: {
                        labels: labels,
                        datasets: [{
                            label: '贡献次数',
                            data: data,
                            borderColor: '#6a11cb',
                            backgroundColor: '#6a11cb33',
                            tension: 0.4,
                            fill: true,
                            pointBackgroundColor: '#6a11cb',
                            pointBorderColor: '#fff',
                            pointBorderWidth: 2,
                            pointRadius: 4
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: {
                                display: false
                            },
                            tooltip: {
                                enabled: true,
                                mode: 'index',
                                intersect: false,
                                backgroundColor: 'rgba(0, 0, 0, 0.8)',
                                titleColor: '#fff',
                                bodyColor: '#fff',
                                padding: 12,
                                displayColors: false,
                                callbacks: {
                                    title: function(context) {
                                        return context[0].label;
                                    },
                                    label: function(context) {
                                        return `提交次数: ${context.parsed.y}`;
                                    }
                                }
                            }
                        },
                        scales: {
                            y: {
                                beginAtZero: true,
                                max: maxCount,  // 设置最高提交次数为顶点
                                grid: {
                                    color: 'rgba(0, 0, 0, 0.05)'
                                },
                                ticks: {
                                    display: false,
                                    font: {
                                        size: 10
                                    }
                                }
                            },
                            x: {
                                grid: {
                                    display: false
                                },
                                ticks: {
                                    font: {
                                        size: 10
                                    }
                                }
                            }
                        }
                    }
                });
            }

            // 诗句轮播功能
            const poems = ["\u4e8c\u516b\u5c11\u5973\u4f53\u4f3c\u9165\uff0c\u8170\u95f4\u4ed7\u5251\u65a9\u51e1\u592b", "\u6625\u6765\u6211\u4e0d\u5148\u5f00\u53e3\uff0c\u54ea\u53ea\u866b\u513f\u6562\u4f5c\u58f0"];
            const poemDisplay = document.getElementById('poem-display');
            if (poemDisplay && poems.length > 0) {
                let currentPoemIndex = 0;
                poemDisplay.textContent = poems[0];
                
                setInterval(function() {
                    currentPoemIndex = (currentPoemIndex + 1) % poems.length;
                    poemDisplay.style.opacity = '0';
                    setTimeout(function() {
                        poemDisplay.textContent = poems[currentPoemIndex];
                        poemDisplay.style.opacity = '1';
                    }, 300);
                }, 6000);
            }
            
            // 悬浮窗功能 - 头像
            const avatar = document.querySelector('.avatar-glow');
            const avatarTooltip = document.getElementById('avatarTooltip');
            if (avatar && avatarTooltip) {
                const tooltips = {"avatar": {"content": "\u4f60\u597d\u5440\u55b5~\u003cbr\u003e\u6211\u662fKlece", "title": "\u6211"}, "tech_stack": {"HTML": {"content": "\u76ee\u524d\u4e0d\u662f\u5f88\u719f\u7ec3", "title": "HTML"}, "Python": {"content": "\u4e00\u79cd\u8bed\u8a00", "title": "Python"}}};
                if (tooltips.avatar) {
                    avatar.addEventListener('mouseenter', function(e) {
                        avatarTooltip.innerHTML = `<strong>${tooltips.avatar.title}</strong><br>${tooltips.avatar.content}`;
                        avatarTooltip.classList.add('show');
                    });
                    avatar.addEventListener('mouseleave', function() {
                        avatarTooltip.classList.remove('show');
                    });
                }
            }
            
            // 悬浮窗功能 - 技术栈标签
            const techStack = [{"color": "#6a11cb", "description": "Python", "name": "Python"}, {"color": "#8B4513", "description": "HTML", "name": "HTML"}];
            const tooltips = {"avatar": {"content": "\u4f60\u597d\u5440\u55b5~\u003cbr\u003e\u6211\u662fKlece", "title": "\u6211"}, "tech_stack": {"HTML": {"content": "\u76ee\u524d\u4e0d\u662f\u5f88\u719f\u7ec3", "title": "HTML"}, "Python": {"content": "\u4e00\u79cd\u8bed\u8a00", "title": "Python"}}};
            if (techStack.length > 0 && tooltips.tech_stack) {
                techStack.forEach((tech, index) => {
                    setTimeout(() => {
                        const techElements = document.querySelectorAll('.tech-stack-item');
                        if (techElements[index]) {
                            const tooltipId = `tooltip-${index}`;
                            let tooltip = document.getElementById(tooltipId);
                            if (!tooltip) {
                                tooltip = document.createElement('div');
                                tooltip.id = tooltipId;
                                tooltip.className = 'tooltip';
                                document.body.appendChild(tooltip);
                            }
                            
                            if (tooltips.tech_stack[tech.name]) {
                                techElements[index].addEventListener('mouseenter', function(e) {
                                    const techInfo = tooltips.tech_stack[tech.name];
                                    tooltip.innerHTML = `<strong>${techInfo.title}</strong><br>${techInfo.content}`;
                                    tooltip.style.left = e.pageX + 10 + 'px';
                                    tooltip.style.top = e.pageY + 10 + 'px';
                                    tooltip.classList.add('show');
                                });
                                techElements[index].addEventListener('mouseleave', function() {
                                    tooltip.classList.remove('show');
                                });
                            }
                        }
                    }, 100 * index);
                });
            }
            
            // 检查本地存储或系统偏好
            const savedTheme = localStorage.getItem('theme');
            const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
            
            // 根据配置设置初始主题
            const configDarkMode = 'auto';
            if (savedTheme) {
                htmlElement.classList.toggle('dark', savedTheme === 'dark');
            } else if (configDarkMode === 'auto') {
                htmlElement.classList.toggle('dark', prefersDark);
            } else if (configDarkMode === 'dark') {
                htmlElement.classList.add('dark');
            }
            
            // 主题切换事件
            themeToggle.addEventListener('click', function() {
                htmlElement.classList.toggle('dark');
                localStorage.setItem('theme', htmlElement.classList.contains('dark') ? 'dark' : 'light');
            });
            
            // 监听系统主题变化
            window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', function(e) {
                if (configDarkMode === 'auto' && !localStorage.getItem('theme')) {
                    htmlElement.classList.toggle('dark', e.matches);
                }
            });
            
            /* 极简模式功能 */
            const minimalModeToggle = document.getElementById('minimal-mode-toggle');
            // 修改选择器，包含所有板块，修复转义字符
            const contentSections = document.querySelectorAll('div.lg\\:col-span-1, div.lg\\:col-span-2 > div');
            const bgImage = document.querySelector('.bg-image');
            let isMinimalMode = false;
            
            // 极简模式切换事件处理
            minimalModeToggle.addEventListener('click', () => {
                isMinimalMode = !isMinimalMode;
                
                if (isMinimalMode) {
                    // 进入极简模式：隐藏所有板块，背景blur效果逐渐消失
                    contentSections.forEach(section => {
                        section.style.transition = 'opacity 0.5s ease, transform 0.5s ease';
                        section.style.opacity = '0';
                        section.style.transform = 'translateY(20px)';
                        section.style.pointerEvents = 'none';
                    });
                    
                    // 移除背景模糊效果
                    if (bgImage) {
                        bgImage.style.transition = 'filter 0.5s ease';
                        bgImage.style.filter = 'blur(0px)';
                    }
                    
                    // 给极简模式按钮添加激活样式
                    minimalModeToggle.classList.add('bg-primary/20', 'dark:bg-primary-dark/20');
                    minimalModeToggle.querySelector('i').classList.add('text-primary', 'dark:text-primary-dark');
                } else {
                    // 退出极简模式：显示所有板块，恢复背景blur效果
                    contentSections.forEach(section => {
                        section.style.transition = 'opacity 0.5s ease, transform 0.5s ease';
                        section.style.opacity = '1';
                        section.style.transform = 'translateY(0)';
                        section.style.pointerEvents = 'auto';
                    });
                    
                    // 恢复背景模糊效果
                    if (bgImage) {
                        bgImage.style.transition = 'filter 0.5s ease';
                        bgImage.style.filter = 'blur(4px)';
                    }
                    
                    // 移除极简模式按钮的激活样式
                    minimalModeToggle.classList.remove('bg-primary/20', 'dark:bg-primary-dark/20');
                    minimalModeToggle.querySelector('i').classList.remove('text-primary', 'dark:text-primary-dark');
                }
            });
            
            // 添加页面滚动动画
            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('animate-fade-in');
                        observer.unobserve(entry.target);
                    }
                });
            }, { threshold: 0.1 });
            
            document.querySelectorAll('.card-hover:not(.animate-fade-in)').forEach(card => {
                observer.observe(card);
            });
        });
    </script>
</body>
</html>