                                QQ
                            </a>
                            
                        </div>
                    </div>
                    
                    <!-- 技术栈 -->
                <div class="mt-6">
                    <h3 class="text-lg font-semibold mb-3">技术栈</h3>
                    <div class="flex flex-wrap gap-2">
                        
                            
                                <div class="tech-stack-item px-3 py-2 rounded-lg text-white text-sm flex flex-col items-center cursor-pointer" style="background-color: #6a11cb;">
                                    <span class="font-medium">Python</span>
                                </div>
                            
                                <div class="tech-stack-item px-3 py-2 rounded-lg text-white text-sm flex flex-col items-center cursor-pointer" style="background-color: #8B4513;">
                                    <span class="font-medium">HTML</span>
                                </div>
                            
                        
                    </div>
                    <!-- 技术栈说明 -->
                    
                    <div class="mt-3 text-xs text-gray-500 dark:text-gray-400 text-center">
